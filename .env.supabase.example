############################################################
# Supabase self-hosted — copy to .env.supabase and fill in
############################################################

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong random string (>= 32 chars) for production:
#   openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Pre-generated JWTs that match the demo JWT_SECRET above.
# *** REPLACE BOTH KEYS FOR PRODUCTION ***
# Use https://supabase.com/docs/guides/self-hosting#api-keys to regenerate.
#
# Payload for ANON_KEY:   {"role":"anon","iss":"supabase-demo","exp":1983812996}
# Payload for SERVICE_KEY: {"role":"service_role","iss":"supabase-demo","exp":1983812996}

ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7W9oNBDAXe_-IpECJpVI-HiuDK-qaapOyU0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-postgres-password

# ── Site / public URLs ───────────────────────────────────────────────────────
# URL visitors use to reach your site (used by GoTrue redirect URLs)
SITE_URL=http://localhost:3000
# Public URL of the Supabase API (Kong). Use your domain in production.
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── Ports (optional overrides) ───────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=54323

# ── Auth settings ────────────────────────────────────────────────────────────
# Set to true to prevent public signups (portfolio doesn't need auth)
DISABLE_SIGNUP=true

# Set to false to skip JWT verification on edge functions (local dev only)
EDGE_VERIFY_JWT=true

############################################################
# Frontend — add these to frontend/.env as well
############################################################
# VITE_SUPABASE_URL=http://localhost:8000
# VITE_SUPABASE_ANON_KEY=<same as ANON_KEY above>
