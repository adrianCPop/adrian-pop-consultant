# n8n Chat Trigger webhook URL
# Format: https://your-n8n-instance.com/webhook/e1fbbe47-646f-4864-bd4e-666f6866430a/chat
VITE_N8N_CHAT_WEBHOOK_URL=

# Supabase — leave blank to use the cloud project, or set for self-hosted local instance
# Self-hosted: VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_URL=
# Self-hosted: copy ANON_KEY from .env.supabase
VITE_SUPABASE_ANON_KEY=
